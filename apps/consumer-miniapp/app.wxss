page {
  background: #f5f7fb;
  color: #15171c;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

.card {
  margin: 20rpx 24rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(17, 24, 39, 0.07);
}

.muted {
  color: #717784;
  font-size: 24rpx;
}

.price {
  color: #f24822;
  font-weight: 900;
}

.tag {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #fff1df;
  color: #f24822;
  font-size: 22rpx;
  font-weight: 900;
}

.tag-warn {
  background: #fff3c7;
  color: #8a5b00;
}

.primary-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffe95a, #ffd51f);
  color: #121212;
  font-weight: 900;
  text-align: center;
  box-shadow: 0 12rpx 24rpx rgba(255, 213, 31, 0.28);
}

.ghost-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: #fff8d8;
  color: #161616;
  font-weight: 900;
  text-align: center;
  border: 1rpx solid #ffe27a;
}
