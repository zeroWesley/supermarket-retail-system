page {
  background: #f3f8f5;
  color: #15171c;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

.card {
  margin: 20rpx 24rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(17, 24, 39, 0.07);
}

.muted {
  color: #717784;
  font-size: 24rpx;
}

.price {
  color: #f24822;
  font-weight: 900;
}

.tag {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eafaf2;
  color: #07834c;
  font-size: 22rpx;
  font-weight: 900;
}

.tag-warn {
  background: #fff2e8;
  color: #f24822;
}

.primary-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #13c978, #079858);
  color: #ffffff;
  font-weight: 900;
  text-align: center;
  box-shadow: 0 12rpx 24rpx rgba(0, 185, 107, 0.24);
}

.ghost-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: #eafaf2;
  color: #07834c;
  font-weight: 900;
  text-align: center;
  border: 1rpx solid #bfead5;
}
