page {
  background: #f3f7f5;
  color: #17211c;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

.card {
  margin: 20rpx 24rpx;
  padding: 26rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 34rpx rgba(16, 36, 28, 0.07);
}

.muted {
  color: #77827c;
  font-size: 24rpx;
}

.price {
  color: #ff4d18;
  font-weight: 900;
}

.tag {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eefaf4;
  color: #07854d;
  font-size: 22rpx;
}

.tag-warn {
  background: #fff1e8;
  color: #b85015;
}

.primary-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #00b96b, #00d084);
  color: #ffffff;
  font-weight: 900;
  text-align: center;
  box-shadow: 0 12rpx 24rpx rgba(0, 185, 107, 0.24);
}

.ghost-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: #eef7f3;
  color: #07854d;
  font-weight: 900;
  text-align: center;
  border: 1rpx solid #ccebdd;
}
