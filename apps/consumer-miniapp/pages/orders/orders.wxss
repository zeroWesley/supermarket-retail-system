.filter-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(180deg, #ffffff, #eefbf5);
  text-align: center;
  color: #697386;
  font-size: 26rpx;
}

.filter-row view {
  padding: 14rpx 0;
  border-radius: 999rpx;
}

.filter-row .active {
  background: #13b66b;
  color: #ffffff;
  font-weight: 900;
}

.order-card {
  margin: 20rpx 24rpx;
  padding: 26rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(17, 24, 39, 0.06);
}

.order-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.order-no {
  font-size: 30rpx;
  font-weight: 900;
}

.order-desc {
  color: #5d6470;
  font-size: 26rpx;
  line-height: 1.45;
}

.order-amount {
  margin-top: 10rpx;
  color: #f24822;
  font-size: 32rpx;
  font-weight: 900;
}

.timeline {
  margin: 22rpx 0;
}

.time-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
  color: #646b76;
  font-size: 24rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #13b66b;
  box-shadow: 0 0 0 6rpx #dff8ec;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}
