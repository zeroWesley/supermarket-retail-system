<view class="page">
  <view class="filter-row">
    <view class="active">全部</view>
    <view>待拣货</view>
    <view>配送中</view>
    <view>已完成</view>
  </view>

  <view wx:for="{{orders}}" wx:key="id" class="order-card">
    <view class="order-head">
      <view class="order-no">订单 #{{item.id}}</view>
      <view class="tag {{item.status === '待拣货' ? 'tag-warn' : ''}}">{{item.status}}</view>
    </view>
    <view class="muted">{{item.items}} · ¥{{item.amount}}</view>
    <view class="timeline">
      <view wx:for="{{item.timeline}}" wx:key="*this" class="time-item">
        <view class="dot"></view>
        <view>{{item}}</view>
      </view>
    </view>
    <view class="action-row">
      <view class="ghost-btn">申请售后</view>
      <view class="primary-btn">查看详情</view>
    </view>
  </view>
</view>
