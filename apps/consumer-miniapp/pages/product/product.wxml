<view class="page" wx:if="{{product}}">
  <view class="cover">
    <image wx:if="{{product.image}}" src="{{product.image}}" mode="aspectFill"></image>
    <text wx:else>{{product.icon}}</text>
  </view>
  <view class="detail">
    <view class="detail-tag">{{product.tag}}</view>
    <view class="price-row">
      <text class="price">¥{{product.displayPrice || product.price}}</text>
      <text wx:if="{{product.memberPrice}}" class="member-badge">会员价</text>
      <text wx:if="{{product.oldPrice}}" class="old-price">¥{{product.oldPrice}}</text>
    </view>
    <view class="title">{{product.name}}</view>
    <view class="muted">{{product.desc}}</view>
    <view class="promise-row">
      <view><text>活动可用</text><text>{{product.tag}}</text></view>
      <view wx:if="{{product.memberPrice}}"><text>会员权益</text><text>{{product.memberLevelName}}专享</text></view>
      <view><text>预计送达</text><text>{{store.eta}}</text></view>
      <view><text>售后保障</text><text>缺货可退</text></view>
    </view>
    <view class="card info">
      <view class="line">
        <text>图片</text>
        <text>{{product.uploadStatus || '后台配置'}}</text>
      </view>
      <view class="line">
        <text>活动</text>
        <text>{{product.tag}}</text>
      </view>
      <view class="line">
        <text>库存</text>
        <text>{{store.name}} · 剩余 {{product.stock}} 件</text>
      </view>
      <view class="line">
        <text>配送</text>
        <text>门店员工自配送</text>
      </view>
      <view class="line">
        <text>提示</text>
        <text>酒类商品请确认购买人已成年</text>
      </view>
    </view>
  </view>
  <view class="bottom-bar">
    <view class="ghost-btn" bindtap="addCart">加入购物车</view>
    <view class="primary-btn" bindtap="buyNow">立即结算</view>
  </view>
</view>
