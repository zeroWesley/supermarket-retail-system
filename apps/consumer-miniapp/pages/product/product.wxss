.cover {
  height: 540rpx;
  line-height: 540rpx;
  background: linear-gradient(135deg, #eafff3, #f7fffb);
  color: #00a761;
  text-align: center;
  font-size: 150rpx;
  font-weight: 900;
}

.cover image {
  display: block;
  width: 100%;
  height: 540rpx;
}

.detail {
  margin-top: -36rpx;
  padding: 34rpx 24rpx 170rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: #ffffff;
}

.detail-tag {
  display: inline-flex;
  margin-bottom: 14rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #eafaf2;
  color: #07834c;
  font-size: 23rpx;
  font-weight: 900;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.price-row .price {
  font-size: 52rpx;
}

.old-price {
  color: #a2aab8;
  font-size: 24rpx;
  text-decoration: line-through;
}

.title {
  margin: 14rpx 0 10rpx;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.3;
}

.promise-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin: 24rpx 0;
}

.promise-row view {
  padding: 18rpx 8rpx;
  border-radius: 20rpx;
  background: #eafaf2;
  color: #07834c;
  text-align: center;
  font-size: 24rpx;
}

.promise-row text {
  display: block;
}

.promise-row text:first-child {
  font-weight: 900;
}

.promise-row text:last-child {
  margin-top: 4rpx;
  color: #617066;
  font-size: 21rpx;
}

.info {
  margin-left: 0;
  margin-right: 0;
}

.line {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eef1f4;
  font-size: 28rpx;
}

.line:last-child {
  border-bottom: 0;
}

.line text:last-child {
  color: #697386;
  text-align: right;
}

.bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 18rpx;
  padding: 18rpx 24rpx 30rpx;
  background: #ffffff;
  border-top: 1rpx solid #eef1f4;
  box-shadow: 0 -12rpx 30rpx rgba(17, 24, 39, 0.08);
}
