.cover {
  height: 520rpx;
  line-height: 520rpx;
  background: linear-gradient(135deg, #eefaf4, #ffffff);
  color: #13b66b;
  text-align: center;
  font-size: 150rpx;
  font-weight: 900;
}

.detail {
  margin-top: -28rpx;
  padding: 32rpx 24rpx 150rpx;
  border-radius: 30rpx 30rpx 0 0;
  background: #ffffff;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.price-row .price {
  font-size: 44rpx;
}

.old-price {
  color: #a2aab8;
  font-size: 24rpx;
  text-decoration: line-through;
}

.title {
  margin: 14rpx 0 10rpx;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.3;
}

.promise-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin: 24rpx 0;
}

.promise-row view {
  padding: 18rpx 8rpx;
  border-radius: 16rpx;
  background: #f6f8fb;
  color: #4f5968;
  text-align: center;
  font-size: 24rpx;
}

.info {
  margin-left: 0;
  margin-right: 0;
}

.line {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e7ebf0;
  font-size: 28rpx;
}

.line:last-child {
  border-bottom: 0;
}

.line text:last-child {
  color: #697386;
  text-align: right;
}

.bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 18rpx;
  padding: 18rpx 24rpx 28rpx;
  background: #ffffff;
  border-top: 1rpx solid #e7ebf0;
}
