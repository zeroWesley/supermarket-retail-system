.page {
  background: #ffffff;
  padding-bottom: 24rpx;
}

.topbar {
  display: grid;
  grid-template-columns: 1fr 180rpx;
  gap: 14rpx;
  padding: 22rpx 24rpx 14rpx;
  background: #ffffff;
}

.search {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #f2f5f8;
  color: #8b8f98;
  font-size: 26rpx;
}

.coupon-pill {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: #fff0f0;
  color: #c9342c;
  text-align: center;
  font-size: 25rpx;
  font-weight: 900;
}

.promise {
  display: flex;
  justify-content: space-between;
  margin: 0 24rpx 12rpx;
  padding: 14rpx 18rpx;
  border: 2rpx solid #ffe368;
  border-radius: 18rpx;
  background: #fffef4;
  color: #171717;
  font-size: 25rpx;
  font-weight: 900;
}

.promise text:first-child {
  font-size: 29rpx;
  font-style: italic;
}

.sort-tabs {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  align-items: center;
  border-top: 1rpx solid #f0f2f5;
  border-bottom: 1rpx solid #f0f2f5;
  background: #ffffff;
  color: #606776;
  text-align: center;
  font-size: 28rpx;
}

.sort-tabs view {
  position: relative;
  padding: 22rpx 0;
}

.sort-tabs .active {
  color: #171717;
  font-weight: 900;
}

.sort-tabs .active::before {
  position: absolute;
  left: 0;
  top: 22rpx;
  width: 8rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: #ffe046;
  content: "";
}

.layout {
  display: grid;
  grid-template-columns: 164rpx 1fr;
  min-height: calc(100vh - 230rpx);
}

.side {
  background: #f2f6fa;
}

.cat {
  padding: 30rpx 12rpx 30rpx 20rpx;
  color: #5b6470;
  font-size: 26rpx;
  line-height: 1.25;
  border-left: 8rpx solid transparent;
}

.cat.active {
  background: #ffffff;
  color: #111827;
  border-left-color: #ffe046;
  font-weight: 900;
}

.list {
  padding: 18rpx 14rpx 34rpx;
  background: #ffffff;
}

.list-banner {
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #ffe959, #fff8c7);
  color: #151515;
}

.list-banner view {
  font-size: 34rpx;
  font-weight: 900;
}

.list-banner text {
  display: block;
  margin-top: 6rpx;
  color: #6f5d18;
  font-size: 22rpx;
}

.product-row {
  display: grid;
  grid-template-columns: 172rpx 1fr;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 26rpx rgba(17, 24, 39, 0.08);
}

.cover {
  width: 172rpx;
  height: 172rpx;
  line-height: 172rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #fff0d8, #eefaff);
  color: #ff7130;
  text-align: center;
  font-size: 58rpx;
  font-weight: 900;
}

.cover image {
  display: block;
  width: 172rpx;
  height: 172rpx;
  border-radius: 22rpx;
}

.body {
  min-width: 0;
}

.name {
  color: #151515;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.36;
}

.mini-tag {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  background: #fff0e7;
  color: #f24822;
  font-size: 21rpx;
  font-weight: 900;
}

.row-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 14rpx;
}

.price {
  font-size: 34rpx;
}

.add {
  width: 58rpx;
  height: 58rpx;
  line-height: 54rpx;
  border-radius: 50%;
  background: #ffe23d;
  color: #171717;
  text-align: center;
  font-size: 42rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 16rpx rgba(255, 213, 31, 0.35);
}

.rank-tip {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  background: #f7eed9;
  color: #9a6a19;
  font-size: 21rpx;
  font-weight: 900;
}
