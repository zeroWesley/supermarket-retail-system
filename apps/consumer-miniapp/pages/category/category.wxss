.search-wrap {
  padding: 22rpx 24rpx;
  background: linear-gradient(180deg, #ffffff, #f3fbf7);
}

.search {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #8b9690;
  font-size: 26rpx;
  box-shadow: inset 0 0 0 1rpx #dce8e2;
}

.layout {
  display: grid;
  grid-template-columns: 180rpx 1fr;
  min-height: calc(100vh - 112rpx);
}

.side {
  background: #f8fbf9;
  border-right: 1rpx solid #dce8e2;
}

.cat {
  padding: 30rpx 14rpx 30rpx 20rpx;
  color: #5f6d65;
  font-size: 26rpx;
  border-left: 8rpx solid transparent;
}

.cat.active {
  background: #ffffff;
  color: #07854d;
  border-left-color: #00b96b;
  font-weight: 900;
}

.list {
  padding: 16rpx;
}

.product-row {
  display: grid;
  grid-template-columns: 164rpx 1fr;
  gap: 18rpx;
  margin-bottom: 16rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(16, 36, 28, 0.06);
}

.cover {
  width: 164rpx;
  height: 164rpx;
  line-height: 164rpx;
  border-radius: 20rpx;
  background: #eefaf4;
  color: #00b96b;
  text-align: center;
  font-size: 60rpx;
  font-weight: 900;
}

.cover image {
  display: block;
  width: 164rpx;
  height: 164rpx;
  border-radius: 20rpx;
}

.name {
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.4;
}

.mini-tag {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #fff2e8;
  color: #e14b16;
  font-size: 21rpx;
  font-weight: 900;
}

.row-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 18rpx;
}

.add {
  min-width: 72rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #00b96b, #00a96a);
  color: #ffffff;
  text-align: center;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(0, 185, 107, 0.22);
}
