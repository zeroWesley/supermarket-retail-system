.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background: #f3f8f5;
}

.member-hero {
  margin: 24rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 88% 8%, rgba(217, 247, 173, .22), transparent 32%),
    linear-gradient(135deg, #080c10, #111827 58%, #0b3a2b);
  color: #ffffff;
  box-shadow: 0 20rpx 44rpx rgba(17, 24, 39, .18);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: flex-start;
}

.eyebrow {
  color: #d9f7ad;
  font-size: 24rpx;
  font-weight: 900;
}

.level-name {
  margin-top: 10rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.meta,
.muted,
.rule {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, .72);
  font-size: 24rpx;
  line-height: 1.45;
}

.level-badge {
  width: 78rpx;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 24rpx;
  background: #d9f7ad;
  color: #111827;
  text-align: center;
  font-size: 44rpx;
  font-weight: 900;
}

.progress-box {
  margin-top: 34rpx;
}

.progress-title {
  font-size: 27rpx;
  font-weight: 900;
}

.progress-track {
  height: 14rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, .16);
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #d9f7ad, #13c978);
}

.section {
  margin: 24rpx;
}

.section-head {
  margin-bottom: 16rpx;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.benefit-card,
.coupon-card,
.price-card {
  display: grid;
  grid-template-columns: 70rpx 1fr;
  gap: 18rpx;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(17, 24, 39, .06);
}

.coupon-card,
.price-card {
  grid-template-columns: 1fr auto;
}

.benefit-icon {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 18rpx;
  background: #111827;
  color: #d9f7ad;
  text-align: center;
  font-weight: 900;
}

.benefit-name,
.coupon-name {
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
}

.section .muted {
  color: #697386;
}

.coupon-amount,
.member-price {
  color: #f24822;
  font-size: 36rpx;
  font-weight: 900;
}
