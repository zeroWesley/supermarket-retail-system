.notice {
  margin: 20rpx 24rpx;
  padding: 20rpx 26rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #fff7ed, #ffffff);
  color: #b03b12;
  font-size: 26rpx;
  font-weight: 900;
  border: 1rpx solid #ffd9bd;
}

.cart-row {
  display: grid;
  grid-template-columns: 150rpx 1fr;
  gap: 18rpx;
  margin: 20rpx 24rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(23, 33, 28, 0.06);
}

.cover {
  width: 150rpx;
  height: 150rpx;
  line-height: 150rpx;
  border-radius: 20rpx;
  background: #eefaf4;
  color: #13b66b;
  text-align: center;
  font-size: 60rpx;
  font-weight: 900;
}

.cover image {
  display: block;
  width: 150rpx;
  height: 150rpx;
  border-radius: 20rpx;
}

.name {
  font-size: 28rpx;
  font-weight: 900;
}

.cart-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 18rpx;
}

.qty {
  display: flex;
  align-items: center;
  gap: 20rpx;
  color: #07854d;
  font-size: 30rpx;
  font-weight: 900;
}

.qty text {
  min-width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 999rpx;
  background: #eefaf4;
  text-align: center;
}

.qty text:nth-child(2) {
  background: transparent;
  color: #17211c;
}

.block-title {
  margin-bottom: 12rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.line {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e2ece6;
  font-size: 26rpx;
}

.line:last-child {
  border-bottom: 0;
}

.line text:last-child {
  color: #697386;
  text-align: right;
}

.checkout {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: 1fr 230rpx;
  gap: 18rpx;
  align-items: center;
  padding: 18rpx 24rpx 28rpx;
  background: #ffffff;
  border-top: 1rpx solid #e2ece6;
  box-shadow: 0 -12rpx 30rpx rgba(23, 33, 28, 0.08);
}

.total {
  font-size: 32rpx;
  font-weight: 900;
}
