.page {
  min-height: 100vh;
  padding-bottom: 170rpx;
  background: #f4f7fb;
}

.coupon-card {
  margin: 20rpx 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(17, 24, 39, 0.06);
}

.coupon-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 62rpx;
  color: #171717;
  font-size: 26rpx;
}

.coupon-line + .coupon-line {
  border-top: 1rpx solid #f0f2f5;
}

.label {
  font-size: 29rpx;
  font-weight: 900;
}

.coupon-tag,
.save-tag {
  padding: 4rpx 10rpx;
  border: 1rpx solid #ffd4cf;
  border-radius: 8rpx;
  color: #c9342c;
  font-size: 22rpx;
}

.save-tag {
  border-color: #ffdf6e;
  background: #fff3c4;
  color: #9a6a19;
  font-weight: 900;
}

.right {
  margin-left: auto;
  color: #171717;
  font-weight: 900;
}

.empty-card {
  margin: 22rpx 24rpx 34rpx;
  padding: 34rpx 28rpx 46rpx;
  border-radius: 30rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 10rpx 28rpx rgba(17, 24, 39, 0.06);
}

.empty-title {
  text-align: left;
  color: #171717;
  font-size: 34rpx;
  font-weight: 900;
}

.empty-illustration {
  position: relative;
  width: 210rpx;
  height: 180rpx;
  margin: 72rpx auto 42rpx;
}

.box-lid {
  position: absolute;
  left: 28rpx;
  top: 10rpx;
  width: 154rpx;
  height: 54rpx;
  border-radius: 12rpx;
  background: #ffe766;
  transform: rotate(-8deg);
  box-shadow: 16rpx 18rpx 24rpx rgba(17, 24, 39, 0.08);
}

.box-body {
  position: absolute;
  left: 40rpx;
  top: 58rpx;
  width: 132rpx;
  height: 104rpx;
  line-height: 104rpx;
  border-radius: 18rpx;
  background: #ffd93a;
  color: #171717;
  font-size: 54rpx;
  font-weight: 900;
}

.empty-text {
  color: #747b86;
  font-size: 28rpx;
}

.empty-btn {
  width: 360rpx;
  height: 84rpx;
  line-height: 84rpx;
  margin: 34rpx auto 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffe95a, #ffd51f);
  color: #121212;
  font-size: 32rpx;
  font-weight: 900;
}

.notice {
  margin: 20rpx 24rpx;
  padding: 20rpx 26rpx;
  border-radius: 22rpx;
  background: #fff7e0;
  color: #9a6a19;
  font-size: 26rpx;
  font-weight: 900;
  border: 1rpx solid #ffdf6e;
}

.cart-row {
  display: grid;
  grid-template-columns: 150rpx 1fr;
  gap: 18rpx;
  margin: 20rpx 24rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(17, 24, 39, 0.06);
}

.cover {
  width: 150rpx;
  height: 150rpx;
  line-height: 150rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #fff0d8, #eefaff);
  color: #ff7130;
  text-align: center;
  font-size: 58rpx;
  font-weight: 900;
}

.cover image {
  display: block;
  width: 150rpx;
  height: 150rpx;
  border-radius: 20rpx;
}

.name {
  font-size: 29rpx;
  font-weight: 900;
}

.cart-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 18rpx;
}

.qty {
  display: flex;
  align-items: center;
  gap: 20rpx;
  color: #171717;
  font-size: 30rpx;
  font-weight: 900;
}

.qty text {
  min-width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 999rpx;
  background: #fff2ba;
  text-align: center;
}

.qty text:nth-child(2) {
  background: transparent;
}

.block-title {
  margin-bottom: 12rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.line {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef1f4;
  font-size: 26rpx;
}

.line:last-child {
  border-bottom: 0;
}

.line text:last-child {
  color: #697386;
  text-align: right;
}

.recommend-title {
  margin: 34rpx 24rpx 18rpx;
  color: #171717;
  font-size: 34rpx;
  font-weight: 900;
}

.recommend-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin: 0 24rpx 24rpx;
}

.recommend-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(17, 24, 39, 0.06);
}

.recommend-cover {
  height: 220rpx;
  line-height: 220rpx;
  background: linear-gradient(135deg, #fff3cc, #f2fff8);
  color: #00a761;
  text-align: center;
  font-size: 72rpx;
  font-weight: 900;
}

.recommend-cover image {
  display: block;
  width: 100%;
  height: 220rpx;
}

.recommend-name {
  min-height: 76rpx;
  padding: 18rpx 18rpx 4rpx;
  color: #171717;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.36;
}

.recommend-card .muted,
.recommend-card .price {
  padding: 0 18rpx 18rpx;
}

.checkout {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: 1fr 230rpx;
  gap: 18rpx;
  align-items: center;
  padding: 18rpx 24rpx 28rpx;
  background: #ffffff;
  border-top: 1rpx solid #eef1f4;
  box-shadow: 0 -12rpx 30rpx rgba(17, 24, 39, 0.08);
}

.total {
  font-size: 32rpx;
  font-weight: 900;
}
