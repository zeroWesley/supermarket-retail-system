<view class="page">
  <view class="top">
    <view class="brand-row">
      <view class="brand-mark">Z</view>
      <view class="brand-name">Zero便利超市</view>
    </view>
    <view class="store-row">
      <view>
        <view class="store-name">{{store.name}}</view>
        <view class="store-meta">营业时间 08:00-02:00 · 配送至绿洲小区</view>
      </view>
      <view class="switch">切换</view>
    </view>
    <view class="search-bar">
      <view class="search">搜索啤酒、水果、牛奶、今日特价</view>
      <view class="search-btn">搜索</view>
    </view>
  </view>

  <view class="quick-panel">
    <view wx:for="{{quickEntries}}" wx:key="name" class="quick-item" bindtap="goCategory" data-id="{{item.id}}">
      <view class="quick-icon">{{item.icon}}</view>
      <view class="quick-name">{{item.name}}</view>
      <view class="quick-note">{{item.note}}</view>
    </view>
  </view>

  <view class="promise-strip">
    <view><text>平均 {{store.eta}}</text><text>慢必赔</text></view>
    <view><text>门店自营</text><text>100%真品</text></view>
  </view>

  <view class="promo-stage">
    <view class="promo-side">
      <view class="promo-label">独家低价</view>
      <view class="promo-title">新品尝鲜</view>
      <view class="promo-go">去看看</view>
    </view>
    <view class="promo-main">
      <view class="hero-kicker">今日鲜达</view>
      <view class="hero-title">{{heroCampaign.title || '今晚吃喝用，一次配齐'}}</view>
      <view class="hero-desc">{{heroCampaign.subtitle || '生鲜酒水员工自配送 · 缺货先确认再处理'}}</view>
      <view class="hero-action" bindtap="openCoupon">领百元券包</view>
    </view>
    <view class="promo-side">
      <view class="promo-label">低至 28.9</view>
      <view class="promo-title">夜间特价</view>
      <view class="promo-go">立即抢</view>
    </view>
  </view>

  <view class="section-title">
    <text>为你推荐</text>
    <text class="muted">后台商品与活动同步展示</text>
  </view>

  <view class="product-grid">
    <view wx:for="{{products}}" wx:key="id" class="product-card" bindtap="goProduct" data-id="{{item.id}}">
      <view class="product-cover">
        <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill"></image>
        <text wx:else>{{item.icon}}</text>
      </view>
      <view class="product-body">
        <view class="product-tag">{{item.tag}}</view>
        <view class="product-name">{{item.name}}</view>
        <view class="muted">{{item.desc}}</view>
        <view class="product-bottom">
          <view>
            <view class="price">¥{{item.price}}</view>
            <view class="muted">库存 {{item.stock}} · 现拣现送</view>
          </view>
          <view class="add" catchtap="addCart" data-id="{{item.id}}">+</view>
        </view>
      </view>
    </view>
  </view>
</view>
