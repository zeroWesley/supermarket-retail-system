<view class="page">
  <view class="top">
    <view class="store-row">
      <view>
        <view class="store-name">{{store.name}}</view>
        <view class="store-meta">配送至绿洲小区 · {{store.distance}} · {{store.eta}}</view>
      </view>
      <view class="switch">切换</view>
    </view>
    <view class="search-bar">
      <view class="search">搜索鲜奶、啤酒、水果、今日特价</view>
      <view class="search-btn">搜索</view>
    </view>
  </view>

  <view class="hero">
    <view class="hero-kicker">今日鲜达</view>
    <view class="hero-title">今晚吃喝用，一次配齐</view>
    <view class="hero-desc">生鲜酒水员工自配送 · 缺货先确认再处理</view>
    <view class="hero-action">领取新人券</view>
  </view>

  <view class="service-row">
    <view><text>约32分钟</text><text>快送到家</text></view>
    <view><text>门店现拣</text><text>新鲜可见</text></view>
    <view><text>缺货确认</text><text>放心退款</text></view>
  </view>

  <view class="coupon-row">
    <view wx:for="{{promotions}}" wx:key="id" class="coupon">
      <view>{{item.name}}</view>
      <text>{{item.target}} 可用</text>
    </view>
  </view>

  <view class="quick-grid">
    <view wx:for="{{quickEntries}}" wx:key="name" class="quick-item">
      <view class="quick-icon">{{item.icon}}</view>
      <view>{{item.name}}</view>
    </view>
  </view>

  <view class="scene-row">
    <view class="scene-card">
      <view class="scene-title">今晚小酌</view>
      <view class="muted">啤酒、零食、冰杯一站配齐</view>
    </view>
    <view class="scene-card">
      <view class="scene-title">下班补货</view>
      <view class="muted">牛奶水果日用品即时送</view>
    </view>
  </view>

  <view class="section-title">
    <text>今日推荐</text>
    <text class="muted">后台活动自动展示</text>
  </view>

  <view class="product-grid">
    <view wx:for="{{products}}" wx:key="id" class="product-card" bindtap="goProduct" data-id="{{item.id}}">
      <view class="product-cover">
        <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill"></image>
        <text wx:else>{{item.icon}}</text>
      </view>
      <view class="product-body">
        <view class="product-tag">{{item.tag}}</view>
        <view class="product-name">{{item.name}}</view>
        <view class="muted">{{item.desc}}</view>
        <view class="product-bottom">
          <view>
            <view class="price">¥{{item.price}}</view>
            <view class="muted">库存 {{item.stock}} · 现拣现送</view>
          </view>
          <view class="add" catchtap="addCart" data-id="{{item.id}}">加购</view>
        </view>
      </view>
    </view>
  </view>
</view>
