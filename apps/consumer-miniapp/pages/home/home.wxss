.top {
  padding: 30rpx 24rpx 28rpx;
  background: linear-gradient(180deg, #00b96b 0%, #46d99a 68%, #f3f7f5 100%);
  color: #ffffff;
}

.store-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.store-name {
  font-size: 38rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.store-meta {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 24rpx;
}

.switch {
  padding: 11rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
}

.search-bar {
  display: grid;
  grid-template-columns: 1fr 112rpx;
  gap: 12rpx;
  align-items: center;
}

.search {
  height: 78rpx;
  line-height: 78rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #77827c;
  font-size: 26rpx;
  box-shadow: 0 8rpx 20rpx rgba(16, 36, 28, 0.12);
}

.search-btn {
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 999rpx;
  background: #064e3b;
  color: #ffffff;
  text-align: center;
  font-size: 26rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 20rpx rgba(6, 78, 59, 0.18);
}

.hero {
  margin: -8rpx 24rpx 20rpx;
  padding: 34rpx 32rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #063f30, #00b96b 58%, #9df8cc);
  box-shadow: 0 18rpx 40rpx rgba(0, 185, 107, 0.22);
}

.hero-kicker {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
  font-weight: 900;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 44rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #e8fff4;
}

.hero-action {
  width: 220rpx;
  margin-top: 26rpx;
  padding: 14rpx 0;
  border-radius: 999rpx;
  background: #ffffff;
  color: #07854d;
  text-align: center;
  font-size: 24rpx;
  font-weight: 900;
}

.service-row,
.coupon-row,
.scene-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin: 0 24rpx 20rpx;
}

.service-row view {
  padding: 18rpx 8rpx 16rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #17211c;
  text-align: center;
  font-size: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(16, 36, 28, 0.06);
}

.service-row text {
  display: block;
}

.service-row text:first-child {
  font-weight: 900;
}

.service-row text:last-child {
  margin-top: 4rpx;
  color: #77827c;
  font-size: 21rpx;
}

.coupon {
  padding: 18rpx 10rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #fff7ed, #ffffff);
  color: #d9480f;
  text-align: center;
  font-size: 24rpx;
  font-weight: 900;
  border: 1rpx solid #ffd9bd;
}

.coupon text {
  display: block;
  margin-top: 4rpx;
  color: #c46b2c;
  font-size: 20rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 22rpx 12rpx;
  margin: 26rpx 24rpx;
  text-align: center;
  color: #253543;
  font-size: 24rpx;
}

.quick-icon {
  width: 76rpx;
  height: 76rpx;
  line-height: 76rpx;
  margin: 0 auto 10rpx;
  border-radius: 28rpx;
  background: #ffffff;
  color: #00b96b;
  font-weight: 900;
  box-shadow: 0 8rpx 22rpx rgba(0, 185, 107, 0.12);
}

.scene-row {
  grid-template-columns: 1fr 1fr;
}

.scene-card {
  padding: 24rpx;
  border: 1rpx solid #d5f2e4;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #effdf6, #ffffff);
}

.scene-title {
  margin-bottom: 6rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 30rpx 24rpx 18rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin: 0 24rpx;
}

.product-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(16, 36, 28, 0.07);
}

.product-cover {
  height: 210rpx;
  line-height: 210rpx;
  background: #e9f8ff;
  color: #00b96b;
  text-align: center;
  font-size: 76rpx;
  font-weight: 900;
}

.product-cover image {
  display: block;
  width: 100%;
  height: 210rpx;
}

.product-body {
  padding: 18rpx 18rpx 20rpx;
}

.product-tag {
  display: inline-flex;
  max-width: 100%;
  margin-bottom: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #fff2e8;
  color: #e14b16;
  font-size: 21rpx;
  font-weight: 900;
}

.product-name {
  min-height: 78rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.4;
}

.product-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 14rpx;
}

.add {
  min-width: 72rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #00b96b, #00a96a);
  color: #ffffff;
  text-align: center;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(0, 185, 107, 0.24);
}
