.page {
  padding-bottom: 160rpx;
  background: #f3f8f5;
}

.top {
  padding: 26rpx 24rpx 34rpx;
  background: linear-gradient(180deg, #08aa62 0%, #16c777 70%, #f3f8f5 100%);
  color: #ffffff;
}

.brand-row,
.store-row,
.search-bar,
.promise-strip,
.product-bottom {
  display: flex;
  align-items: center;
}

.brand-row {
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.brand-mark {
  width: 54rpx;
  height: 54rpx;
  line-height: 54rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #08aa62;
  text-align: center;
  font-size: 34rpx;
  font-weight: 900;
}

.brand-name {
  font-size: 38rpx;
  font-weight: 900;
}

.store-row {
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.store-name {
  font-size: 31rpx;
  font-weight: 900;
}

.store-meta {
  margin-top: 7rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 23rpx;
}

.switch {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  border: 1rpx solid rgba(255, 255, 255, 0.26);
}

.search-bar {
  gap: 12rpx;
}

.search {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #8b8f98;
  font-size: 27rpx;
  box-shadow: 0 8rpx 20rpx rgba(17, 24, 39, 0.08);
}

.search::before {
  content: "";
}

.search-btn {
  width: 108rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: #064b32;
  color: #ffffff;
  text-align: center;
  font-size: 27rpx;
  font-weight: 900;
}

.quick-panel {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 22rpx 6rpx;
  margin: -8rpx 24rpx 18rpx;
  padding: 28rpx 14rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(17, 24, 39, 0.07);
}

.quick-item {
  text-align: center;
}

.quick-icon {
  width: 78rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0 auto 8rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #e7fff2, #ffffff 62%);
  color: #07834c;
  font-size: 31rpx;
  font-weight: 900;
  box-shadow: inset -8rpx -8rpx 0 rgba(0, 185, 107, 0.09);
}

.quick-name {
  color: #171717;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

.quick-note {
  margin-top: 3rpx;
  color: #07834c;
  font-size: 18rpx;
}

.promise-strip {
  justify-content: space-between;
  margin: 0 24rpx 18rpx;
  padding: 14rpx 22rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 2rpx solid #bfead5;
}

.promise-strip view {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  color: #171717;
  font-size: 25rpx;
}

.promise-strip text:first-child {
  font-size: 32rpx;
  font-weight: 900;
  font-style: italic;
}

.promise-strip text:last-child {
  color: #4f5661;
  font-weight: 800;
}

.promo-stage {
  display: grid;
  grid-template-columns: 1fr 1.8fr 1fr;
  gap: 10rpx;
  margin: 0 24rpx 22rpx;
}

.promo-side,
.promo-main,
.product-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(17, 24, 39, 0.07);
}

.promo-side {
  min-height: 190rpx;
  padding: 20rpx 16rpx;
  background: linear-gradient(150deg, #ecfff6, #ffffff);
  border: 2rpx solid #bfead5;
}

.promo-label {
  color: #0f8f55;
  font-size: 20rpx;
  font-weight: 900;
}

.promo-title {
  margin-top: 44rpx;
  color: #171717;
  font-size: 26rpx;
  font-weight: 900;
}

.promo-go {
  display: inline-flex;
  margin-top: 12rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #07834c;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
}

.promo-main {
  min-height: 190rpx;
  padding: 22rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #063f30, #00b96b 58%, #9df8cc);
}

.hero-kicker {
  display: inline-flex;
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 21rpx;
  font-weight: 900;
}

.hero-title {
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 8rpx;
  color: #e8fff4;
  font-size: 22rpx;
  line-height: 1.4;
}

.hero-action {
  width: 190rpx;
  margin-top: 16rpx;
  padding: 12rpx 0;
  border-radius: 999rpx;
  background: #ffffff;
  color: #07834c;
  text-align: center;
  font-size: 22rpx;
  font-weight: 900;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 28rpx 24rpx 16rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin: 0 24rpx;
}

.product-cover {
  height: 222rpx;
  line-height: 222rpx;
  background: linear-gradient(135deg, #eafff3, #f7fffb);
  color: #00a761;
  text-align: center;
  font-size: 72rpx;
  font-weight: 900;
}

.product-cover image {
  display: block;
  width: 100%;
  height: 222rpx;
}

.product-body {
  padding: 18rpx 18rpx 20rpx;
}

.product-tag {
  display: inline-flex;
  max-width: 100%;
  margin-bottom: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #fff0e7;
  color: #f24822;
  font-size: 21rpx;
  font-weight: 900;
}

.product-name {
  min-height: 78rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.4;
}

.product-bottom {
  justify-content: space-between;
  margin-top: 14rpx;
}

.add {
  width: 58rpx;
  height: 58rpx;
  line-height: 54rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #13c978, #079858);
  color: #ffffff;
  text-align: center;
  font-size: 42rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 16rpx rgba(0, 185, 107, 0.28);
}
