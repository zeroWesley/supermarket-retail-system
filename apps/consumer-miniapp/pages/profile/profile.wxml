<view class="page">
  <view class="profile-hero">
    <view class="title-row">
      <view class="avatar">Z</view>
      <view class="user">
        <view class="name">ZeroWesley ›</view>
        <view class="desc">Zero便利超市 · 城南店常购用户</view>
      </view>
    </view>
  </view>

  <view class="coupon-row">
    <view class="ticket-icon">券</view>
    <view class="coupon-title">我的优惠券</view>
    <view class="coupon-count">7张券可用 ›</view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <text>我的订单</text>
      <text>全部订单 ›</text>
    </view>
    <view class="order-grid">
      <view wx:for="{{orderActions}}" wx:key="name" class="order-action">
        <view>{{item.icon}}</view>
        <text>{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="service-grid section-card">
    <view wx:for="{{services}}" wx:key="name" class="service-item">
      <view>{{item.icon}}</view>
      <text>{{item.name}}</text>
    </view>
  </view>
</view>
