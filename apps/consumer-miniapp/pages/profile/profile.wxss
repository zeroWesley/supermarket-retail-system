.page {
  min-height: 100vh;
  background: #f3f8f5;
  padding-bottom: 34rpx;
}

.profile-hero {
  padding: 44rpx 24rpx 30rpx;
  background: linear-gradient(180deg, #dffff0, #f3fff9 78%, #f3f8f5 100%);
}

.title-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-bottom: 28rpx;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  line-height: 108rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #08aa62, #064b32);
  color: #ffffff;
  text-align: center;
  font-size: 60rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 24rpx rgba(17, 24, 39, 0.18);
}

.name {
  color: #171717;
  font-size: 42rpx;
  font-weight: 900;
}

.desc {
  margin-top: 8rpx;
  color: #617066;
  font-size: 24rpx;
}

.coupon-row,
.section-card {
  margin: 20rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(17, 24, 39, 0.06);
}

.coupon-row {
  display: grid;
  grid-template-columns: 52rpx 1fr 180rpx;
  gap: 14rpx;
  align-items: center;
  padding: 24rpx;
}

.ticket-icon {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 10rpx;
  background: #eafaf2;
  color: #07834c;
  text-align: center;
  font-weight: 900;
}

.coupon-title {
  font-size: 31rpx;
  font-weight: 900;
}

.coupon-count {
  color: #171717;
  text-align: right;
  font-size: 25rpx;
  font-weight: 900;
}

.section-card {
  padding: 26rpx 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid #eef1f4;
}

.section-head text:first-child {
  color: #171717;
  font-size: 33rpx;
  font-weight: 900;
}

.section-head text:last-child {
  color: #8b8f98;
  font-size: 25rpx;
}

.order-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  padding-top: 26rpx;
  text-align: center;
}

.order-action view,
.service-item view {
  width: 58rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0 auto 10rpx;
  border-radius: 16rpx;
  border: 3rpx solid #171717;
  color: #171717;
  font-size: 26rpx;
  font-weight: 900;
}

.order-action text,
.service-item text {
  color: #171717;
  font-size: 24rpx;
}

.service-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30rpx 10rpx;
  text-align: center;
}
