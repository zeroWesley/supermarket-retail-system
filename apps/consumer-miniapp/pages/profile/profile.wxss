.profile-hero {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 46rpx 32rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #13b66b, #07854d);
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  line-height: 110rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #13b66b;
  text-align: center;
  font-size: 60rpx;
  font-weight: 900;
}

.name {
  font-size: 38rpx;
  font-weight: 900;
}

.desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
}

.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  text-align: center;
}

.num {
  font-size: 34rpx;
  font-weight: 900;
  color: #07854d;
}

.menu {
  padding-top: 0;
  padding-bottom: 0;
}

.menu-row {
  padding: 26rpx 0;
  border-bottom: 1rpx solid #e7ebf0;
  font-size: 29rpx;
}

.menu-row:last-child {
  border-bottom: 0;
}

.menu-row .muted {
  display: block;
  margin-top: 8rpx;
}
