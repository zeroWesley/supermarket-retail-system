.top-filter {
  position: sticky;
  top: 0;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  padding: 18rpx 24rpx;
  background: #f3f8f5;
}

.tab {
  height: 66rpx;
  line-height: 66rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #697386;
  text-align: center;
  font-weight: 800;
  box-shadow: inset 0 0 0 1rpx #e6edf0;
}

.tab .active {
  display: block;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #13c978, #079858);
  color: #ffffff;
}

.search {
  box-sizing: border-box;
  width: auto;
  margin: 0 24rpx 20rpx;
  height: 76rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #18212f;
  font-size: 26rpx;
  box-shadow: inset 0 0 0 1rpx #e5edf0;
}

.order-card {
  overflow: hidden;
}

.goods {
  margin: 22rpx 0 8rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f0fbf5;
  font-size: 28rpx;
  font-weight: 800;
}

.progress {
  height: 10rpx;
  margin: 22rpx 0 10rpx;
  border-radius: 999rpx;
  background: #e7ebf0;
  overflow: hidden;
}

.bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #13b66b, #7be3aa);
}

.empty {
  margin: 80rpx 24rpx;
  padding: 54rpx 24rpx;
  border-radius: 26rpx;
  background: #ffffff;
  text-align: center;
}

.empty-title {
  margin-bottom: 10rpx;
  font-size: 32rpx;
  font-weight: 900;
}
