<view class="page">
  <view class="search">搜索订单号/手机号/地址</view>
  <view wx:for="{{orders}}" wx:key="id" class="card">
    <view class="row">
      <view class="strong">#{{item.id}} {{item.user}}</view>
      <view class="tag {{item.status === '待接单' ? 'tag-warn' : ''}}">{{item.status}}</view>
    </view>
    <view class="muted">{{item.items}} · ¥{{item.amount}}</view>
    <view class="muted">{{item.address}} · {{item.phone}}</view>
    <view class="muted">备注：{{item.remark}}</view>
    <view class="action-row">
      <view class="primary-btn" bindtap="acceptOrder" data-id="{{item.id}}">{{item.status === '待接单' ? '接单' : '去拣货'}}</view>
      <view class="ghost-btn">查看地址</view>
    </view>
  </view>
</view>
