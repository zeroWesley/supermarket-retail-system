<view class="page safe-bottom">
  <view class="notice" wx:if="{{order}}">
    <view class="strong">订单 #{{order.id}}</view>
    <view class="muted">{{order.user}} · {{order.address}}</view>
    <view class="muted">逐项扫码核验，完成后生成出库状态。</view>
  </view>

  <view wx:for="{{items}}" wx:key="id" class="card">
    <view class="row">
      <view>
        <view class="strong">{{item.name}}</view>
        <view class="muted">应拣 {{item.required}} · 货架库存 {{item.stock}}</view>
      </view>
      <view class="tag {{item.status === '库存预警' ? 'tag-danger' : item.status === '待核验' ? 'tag-warn' : ''}}">{{item.status}}</view>
    </view>
    <view class="action-row">
      <view class="primary-btn" bindtap="checkItem" data-id="{{item.id}}">扫码确认</view>
      <view class="danger-btn" bindtap="reportItem" data-id="{{item.id}}">异常上报</view>
    </view>
  </view>

  <view class="bottom">
    <view class="primary-btn" bindtap="finishPicking">完成出库并同步订单</view>
  </view>
</view>
