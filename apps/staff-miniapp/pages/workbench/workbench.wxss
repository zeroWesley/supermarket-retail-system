.hero {
  padding: 34rpx 28rpx 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #13b66b, #07854d);
}

.hero-top,
.route-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 900;
}

.desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
}

.online {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 24rpx;
  font-weight: 800;
}

.route-card {
  margin-top: 28rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.14);
}

.route-card .muted {
  color: rgba(255, 255, 255, 0.72);
}

.route-text {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  margin: 24rpx;
}

.metric {
  padding: 26rpx 10rpx;
  border-radius: 18rpx;
  background: #ffffff;
  text-align: center;
}

.num {
  color: #07854d;
  font-size: 44rpx;
  font-weight: 900;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin: 24rpx;
}

.quick {
  padding: 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(24, 33, 47, 0.05);
}

.quick.primary {
  background: #0f9f5d;
  color: #ffffff;
}

.quick-title {
  font-size: 30rpx;
  font-weight: 900;
}

.quick-desc {
  margin-top: 10rpx;
  color: #697386;
  font-size: 24rpx;
}

.quick.primary .quick-desc {
  color: rgba(255, 255, 255, 0.78);
}
