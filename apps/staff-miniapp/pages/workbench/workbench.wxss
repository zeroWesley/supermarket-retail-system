.hero {
  padding: 34rpx 28rpx 30rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #08aa62, #13c978 62%, #7ef0b7);
}

.hero-top,
.route-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 900;
}

.desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
}

.online {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  font-size: 24rpx;
  font-weight: 800;
}

.route-card {
  margin-top: 28rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.route-card .muted {
  color: rgba(255, 255, 255, 0.72);
}

.route-text {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  margin: 24rpx;
}

.metric {
  padding: 28rpx 10rpx;
  border-radius: 24rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 10rpx 26rpx rgba(24, 33, 47, 0.06);
}

.num {
  color: #07854d;
  font-size: 44rpx;
  font-weight: 900;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin: 24rpx;
}

.quick {
  min-height: 146rpx;
  padding: 26rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(24, 33, 47, 0.07);
  border: 1rpx solid #edf2f0;
}

.quick.primary {
  background: linear-gradient(135deg, #0f9f5d, #13c978);
  color: #ffffff;
}

.quick-title {
  font-size: 31rpx;
  font-weight: 900;
}

.quick-desc {
  margin-top: 10rpx;
  color: #697386;
  font-size: 24rpx;
}

.quick.primary .quick-desc {
  color: rgba(255, 255, 255, 0.78);
}
