<view class="page">
  <view class="filter-card">
    <input class="search" placeholder="搜索订单号、用户、地址" value="{{keyword}}" bindinput="onKeyword" />
    <picker mode="selector" range="{{ranges}}" value="{{rangeIndex}}" bindchange="chooseRange">
      <view class="range">{{range}} ▾</view>
    </picker>
  </view>

  <view wx:if="{{!orders.length}}" class="empty">
    <view class="empty-title">没有匹配的历史订单</view>
    <view class="muted">换个关键词或时间范围试试。</view>
  </view>

  <view wx:for="{{orders}}" wx:key="id" class="card history-card" bindtap="viewDetail" data-id="{{item.id}}">
    <view class="row">
      <view>
        <view class="strong">#{{item.id}} {{item.user}}</view>
        <view class="muted">{{item.finishedAt}} · {{item.address}}</view>
      </view>
      <view class="tag">{{item.status}}</view>
    </view>
    <view class="line"><text>商品</text><text>{{item.items}}</text></view>
    <view class="line"><text>金额</text><text>¥{{item.amount}}</text></view>
  </view>
</view>
