.scan-box {
  display: grid;
  place-items: center;
  min-height: 330rpx;
  margin: 24rpx;
  border: 4rpx dashed #8ae0b6;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #e7fff2, #ffffff);
  color: #07854d;
  text-align: center;
}

.scan-icon {
  font-size: 72rpx;
  font-weight: 900;
}

.scan-title {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 900;
}

.form-card {
  padding-top: 10rpx;
  padding-bottom: 10rpx;
}

.qty-input {
  width: 180rpx;
  height: 58rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #f3f8f5;
  color: #18212f;
  text-align: right;
}

.card-actions {
  margin: 20rpx 24rpx;
}

.disabled {
  opacity: .48;
}

.record {
  margin: 14rpx 24rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #ffffff;
}
