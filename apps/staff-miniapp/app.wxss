page {
  background: #f6f8fb;
  color: #18212f;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

.card {
  margin: 20rpx 24rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(24, 33, 47, 0.06);
}

.muted {
  color: #697386;
  font-size: 24rpx;
}

.tag {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eefaf4;
  color: #07854d;
  font-size: 22rpx;
}

.tag-warn {
  background: #fff1e8;
  color: #b85015;
}

.tag-danger {
  background: #fff0f1;
  color: #e5484d;
}

.primary-btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: #13b66b;
  color: #ffffff;
  font-weight: 800;
  text-align: center;
}

.ghost-btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: #eef2f6;
  color: #18212f;
  font-weight: 700;
  text-align: center;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 20rpx;
}
