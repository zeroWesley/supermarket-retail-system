page {
  background: #f3f8f5;
  color: #18212f;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.safe-bottom {
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
}

.card {
  margin: 20rpx 24rpx;
  padding: 26rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(24, 33, 47, 0.07);
}

.muted {
  color: #697386;
  font-size: 24rpx;
}

.tag {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eefaf4;
  color: #07854d;
  font-size: 22rpx;
}

.tag-warn {
  background: #fff1e8;
  color: #b85015;
}

.tag-danger {
  background: #fff0f1;
  color: #e5484d;
}

.primary-btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #13c978, #079858);
  color: #ffffff;
  font-weight: 800;
  text-align: center;
  box-shadow: 0 10rpx 20rpx rgba(0, 185, 107, 0.22);
}

.ghost-btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: #eafaf2;
  color: #07854d;
  font-weight: 700;
  text-align: center;
}

.danger-btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: #fff0f1;
  color: #e5484d;
  font-weight: 800;
  text-align: center;
}

.small-btn {
  min-width: 132rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #e7fff2;
  color: #07854d;
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.strong {
  font-size: 30rpx;
  font-weight: 900;
}

.section-title {
  margin: 30rpx 24rpx 8rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.input-like {
  height: 74rpx;
  line-height: 74rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #7d8794;
  font-size: 26rpx;
  box-shadow: inset 0 0 0 1rpx #e5edf0;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 20rpx;
}

.action-row.three {
  grid-template-columns: repeat(3, 1fr);
}

.line {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e7ebf0;
  font-size: 27rpx;
}

.line:last-child {
  border-bottom: 0;
}

.line text:last-child {
  color: #697386;
  text-align: right;
}
